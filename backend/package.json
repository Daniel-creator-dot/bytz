{
  "name": "bytz-academy-backend",
  "version": "1.0.0",
  "description": "Express.js backend for BYTZ Academy",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build needed for backend'",
